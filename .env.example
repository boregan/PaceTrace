# Strava API application credentials (same for all users)
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# Supabase project credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Webhook verification token (make up a random string)
STRAVA_WEBHOOK_VERIFY_TOKEN=your_random_verify_token_here

# API bearer token — protects the /activity and /athlete endpoints
API_SECRET=your_random_api_secret_here

# MCP server defaults (used when running mcp_server.py locally)
PACETRACE_USER=ben
PACETRACE_MAX_HR=185
